#include <stdio.h>
#include <math.h>

int main() {
    long long binary;
    int decimal = 0, i = 0, remainder;

    printf("Enter a binary number: ");
    scanf("%lld", &binary);

    while (binary != 0) {
        // Get the last digit
        remainder = binary % 10;
        // Remove the last digit from the binary number
        binary /= 10;
        // Calculate decimal value: digit * 2^position
        decimal += remainder * pow(2, i);
        ++i;
    }

    printf("Decimal equivalent = %d\n", decimal);

    return 0;
}
