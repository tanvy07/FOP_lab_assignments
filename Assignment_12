#include <stdio.h>

int main() {
    int a, b, i, gcd, scd = -1;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    // GCD using Euclidean Algorithm
    int x = a, y = b;
    while (y != 0) {
        int temp = y;
        y = x % y;
        x = temp;
    }
    gcd = x;

    // Smallest common divisor > 1
    for(i = 2; i <= (a < b ? a : b); i++) {
        if(a % i == 0 && b % i == 0) {
            scd = i;
            break;
        }
    }

    if(scd == -1)
        printf("No common divisor other than 1\n");
    else
        printf("Smallest Common Divisor = %d\n", scd);

    printf("GCD = %d\n", gcd);

    return 0;
}
