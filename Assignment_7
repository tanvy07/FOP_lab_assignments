#include <stdio.h>

struct student {
    int roll;
    char name[50];
    int marks[3];
    int total;
    float per;
};

int main(){
    struct student s[10];
    int n, i, j;

    printf("Enter number of students: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        printf("\nStudent %d\n", i+1);

        printf("Roll: ");
        scanf("%d",&s[i].roll);

        printf("Name: ");
        scanf("%s", s[i].name);

        printf("Enter 3 marks: ");
        for(j=0;j<3;j++)
            scanf("%d",&s[i].marks[j]);

        s[i].total = 0;
        for(j=0;j<3;j++)
            s[i].total += s[i].marks[j];

        s[i].per = s[i].total / 3.0;
    }

    printf("\n--- Results ---\n");
    for(i=0;i<n;i++){
        printf("\nRoll: %d", s[i].roll);
        printf("\nName: %s", s[i].name);
        printf("\nTotal: %d", s[i].total);
        printf("\nPercentage: %.2f\n", s[i].per);
    }

    return 0;
}
